.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.picker-arrow {
  color: #ccc;
  font-size: 32rpx;
}

.test-row {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.test-result {
  font-size: 26rpx;
}

.password-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.toggle-pwd {
  padding: 12rpx 20rpx;
  background: #f0f0f0;
  border-radius: 8rpx;
  font-size: 24rpx;
  color: #666;
  white-space: nowrap;
}

.category-list {
  margin-top: 10rpx;
}

.category-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.category-item:last-child {
  border-bottom: none;
}

.category-name {
  font-size: 28rpx;
  color: #333;
}

.category-delete {
  font-size: 28rpx;
  color: #e74c3c;
  padding: 4rpx 12rpx;
}

.template-list {
  margin-top: 10rpx;
}

.template-card {
  padding: 16rpx 20rpx;
  background: #f8f9fa;
  border-radius: 10rpx;
  margin-bottom: 12rpx;
}

.template-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  display: block;
  margin-bottom: 6rpx;
}

.template-desc {
  font-size: 24rpx;
  color: #999;
}
