.month-header {
  padding: 20rpx 0;
}

.month-nav {
  display: flex;
  justify-content: center;
  align-items: center;
}

.nav-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  justify-content: center;
  align-items: center;
}

.arrow {
  font-size: 32rpx;
  color: #4A90D9;
}

.month-text {
  font-size: 34rpx;
  font-weight: 600;
  margin: 0 30rpx;
}

.overview-card {
  padding: 40rpx 30rpx;
}

.total-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.total-label {
  font-size: 30rpx;
  color: #666;
}

.split-row {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.split-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.split-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.split-amount {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.split-status {
  font-size: 22rpx;
}

.split-divider {
  width: 2rpx;
  height: 80rpx;
  background: #eee;
}

.pie-placeholder {
  padding-top: 20rpx;
  border-top: 1rpx solid #f0f0f0;
}

.pie-chart {
  display: flex;
  height: 20rpx;
  border-radius: 10rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
}

.pie-daily {
  background: #4A90D9;
  min-width: 4rpx;
}

.pie-extra {
  background: #f57c00;
  min-width: 4rpx;
}

.pie-legend {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #666;
}

.legend-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}

.legend-dot.daily {
  background: #4A90D9;
}

.legend-dot.extra {
  background: #f57c00;
}

.project-list {
  margin-top: 10rpx;
}

.project-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.project-item:last-child {
  border-bottom: none;
}

.project-info {
  display: flex;
  align-items: center;
}

.project-name {
  font-size: 28rpx;
  font-weight: 500;
  margin-right: 16rpx;
}

.project-count {
  font-size: 22rpx;
  color: #999;
}

.project-amount {
  font-size: 28rpx;
  font-weight: 600;
}

.bill-list {
  margin-top: 10rpx;
}

.empty {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 100rpx 0;
}

.empty-text {
  color: #ccc;
  font-size: 28rpx;
}
