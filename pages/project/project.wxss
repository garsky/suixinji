.project-list {
  margin-top: 10rpx;
}

.project-card {
  padding: 24rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.project-card.closed {
  opacity: 0.6;
}

.project-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.project-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.project-tags {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.project-type-tag {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.project-type-tag.type-time {
  background: #e3f2fd;
  color: #1976d2;
}

.project-type-tag.type-keyword {
  background: #fff3e0;
  color: #f57c00;
}

.detail-type-tag {
  font-size: 24rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.detail-type-tag.type-time {
  background: #e3f2fd;
  color: #1976d2;
}

.detail-type-tag.type-keyword {
  background: #fff3e0;
  color: #f57c00;
}

.project-status {
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 8rpx;
}

.project-status.active {
  background: #e8f5e9;
  color: #27ae60;
}

.project-status.closed {
  background: #f5f5f5;
  color: #999;
}

.project-meta {
  margin-bottom: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #999;
}

.project-budget {
  display: flex;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #f0f0f0;
}

.budget-label {
  font-size: 24rpx;
  color: #999;
}

.budget-value {
  font-size: 24rpx;
  color: #4A90D9;
  font-weight: 500;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 180rpx;
  width: 100rpx;
  height: 100rpx;
  border-radius: 50%;
  background: #4A90D9;
  display: flex;
  justify-content: center;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(74, 144, 217, 0.4);
  z-index: 50;
}

.fab-icon {
  font-size: 48rpx;
  color: #fff;
  line-height: 1;
}

.popup-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
}

.popup {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  z-index: 101;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.popup.show {
  transform: translateY(0);
}

.popup-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.popup-title {
  font-size: 32rpx;
  font-weight: 600;
}

.popup-close {
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.popup-body {
  padding: 30rpx;
  max-height: 60vh;
  overflow-y: auto;
}

.popup-detail .popup-body {
  max-height: 70vh;
}

.popup-footer {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
}

.popup-footer .btn-secondary,
.popup-footer .btn-primary,
.popup-footer .btn-danger {
  flex: 1;
}

.form-group {
  margin-bottom: 24rpx;
}

.form-label {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 10rpx;
  display: block;
}

.form-input {
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.form-picker {
  display: flex;
  justify-content: space-between;
  align-items: center;
  border: 1rpx solid #e0e0e0;
  border-radius: 10rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
}

.type-tabs {
  display: flex;
  gap: 16rpx;
}

.type-tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx 16rpx;
  border: 2rpx solid #e0e0e0;
  border-radius: 12rpx;
  font-size: 26rpx;
  color: #666;
}

.type-tab.active {
  border-color: #4A90D9;
  background: #e8f4fd;
  color: #4A90D9;
}

.type-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.type-desc {
  margin-top: 12rpx;
}

.type-desc-text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}

.form-hint {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  display: block;
}

.detail-summary {
  margin-bottom: 30rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.detail-label {
  font-size: 26rpx;
  color: #999;
}

.detail-bills {
  margin-top: 20rpx;
}

.bill-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.bill-item:last-child {
  border-bottom: none;
}

.bill-info {
  display: flex;
  flex-direction: column;
}

.bill-merchant {
  font-size: 28rpx;
  color: #333;
}

.bill-meta {
  font-size: 22rpx;
  color: #999;
  margin-top: 4rpx;
}

.bill-amount {
  font-size: 28rpx;
  font-weight: 600;
}

.empty-bills {
  text-align: center;
  padding: 40rpx 0;
  color: #ccc;
  font-size: 26rpx;
}
