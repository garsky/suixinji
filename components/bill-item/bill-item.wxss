.bill-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.bill-item:last-child {
  border-bottom: none;
}

.bill-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.bill-category-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #e8f4fd;
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 28rpx;
  color: #4A90D9;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.bill-info {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.bill-merchant {
  font-size: 28rpx;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.bill-meta-row {
  display: flex;
  gap: 12rpx;
  margin-top: 4rpx;
}

.bill-category {
  font-size: 22rpx;
  color: #999;
}

.bill-channel {
  font-size: 22rpx;
  color: #4A90D9;
}

.bill-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 6rpx;
}

.bill-right {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.bill-amount {
  font-size: 30rpx;
  font-weight: 600;
}
