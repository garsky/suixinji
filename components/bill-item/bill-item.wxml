<view class="bill-item" bindtap="onTap">
  <view class="bill-left">
    <view class="bill-category-icon">
      <text>{{bill.category[0] || '?'}}</text>
    </view>
    <view class="bill-info">
      <text class="bill-merchant">{{bill.merchant || '未知'}}</text>
      <view class="bill-meta-row">
        <text class="bill-category">{{bill.category}}</text>
        <text class="bill-channel" wx:if="{{bill.channel}}">{{bill.channel}}</text>
      </view>
      <view class="bill-tags" wx:if="{{bill.tags && bill.tags.length > 0}}">
        <text class="tag {{bill.level === 'extra' ? 'tag-extra' : ''}}" wx:for="{{bill.tags}}" wx:key="*this" wx:for-item="tag">{{tag}}</text>
      </view>
    </view>
  </view>
  <view class="bill-right">
    <text class="bill-amount {{bill.type === 'income' ? 'amount-income' : 'amount-expense'}}">
      {{bill.type === 'income' ? '+' : '-'}}¥{{bill.amount}}
    </text>
  </view>
</view>
